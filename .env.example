# ─── Telegram ────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The chat ID of the group where OTP codes will be posted.
# For groups this is a negative number, e.g. -1001234567890
# Tip: Start the bot and send /chatid in your group to get it.
TELEGRAM_CHAT_ID=your_group_chat_id_here

# ─── Email / IMAP ────────────────────────────────────────────────────────────
EMAIL_ADDRESS=your_email@gmail.com

# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# Outlook: use your regular password or an App Password if MFA is enabled
EMAIL_PASSWORD=your_app_password_here

# Common IMAP servers:
#   Gmail:          imap.gmail.com        port 993
#   Outlook/Hotmail: outlook.office365.com port 993
#   Yahoo:          imap.mail.yahoo.com   port 993
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# ─── Bot behaviour ───────────────────────────────────────────────────────────
# How often (in seconds) to check for new emails
POLL_INTERVAL_SECONDS=30

# Sender address(es) to watch for Netflix emails (comma-separated if multiple)
# Common Netflix senders:
#   info@account.netflix.com
#   info@mailer.netflix.com
NETFLIX_SENDER=info@account.netflix.com,info@mailer.netflix.com
